# Registry and transport hardening
registry=https://registry.npmjs.org/
strict-ssl=true

# Integrity checks
verify-store-integrity=true
strict-store-pkg-content-check=true

# Script execution policy (supply-chain mitigation)
ignore-scripts=true

# Delay very recent releases to reduce zero-day package risk (448)
minimum-release-age=2880

# Block exotic transitive dependency sources (git/tarball URLs)
block-exotic-subdeps=true

# Fail fast on incompatible engines and broken peer ranges
engine-strict=true
strict-peer-dependencies=true
